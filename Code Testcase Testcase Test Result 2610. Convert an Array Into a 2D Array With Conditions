class Solution {
public:
    vector<vector<int>> findMatrix(vector<int>& nums) {
        int n=nums.size();
        vector<vector<int>> ans;
        unordered_map<int,int> mp;
        for(int i=0;i<n;i++)
        {
            int freq=mp[nums[i]];
            if(ans.size()==freq)
            {
                ans.push_back({});
            }
            ans[freq].push_back(nums[i]);
            mp[nums[i]]++;
        }
        return ans;
    }
};
