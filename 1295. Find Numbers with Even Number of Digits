class Solution {
public:
    int findNumbers(vector<int>& nums) {
        int count1=0;
        for(int i=0;i<nums.size();i++)
        {
            int count2=0;
            int num=nums[i];
            while(num != 0)
            {
                num=num/10;
                count2++;               
            }
             if(count2%2==0)
                {
                    count1++;
                }
        }
        return count1;
    }
};
